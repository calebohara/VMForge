# Dependencies
node_modules

# Build output
dist
dist-ssr
*.local

# Rust / Cargo (workspace target at root)
/target

# Tauri generated capability schemas
src-tauri/gen/schemas

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# VMForge runtime data (VM library, disks, sockets) — never commit
/.vmforge-data
*.qcow2
*.sock
# Stray qemu-img artifacts: a size arg ("2G") used as a relative output path
# lands a 0-byte file in the crate root. Never commit these.
/crates/vmforge-core/[0-9]*G

# Editor / OS
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.swp
